{
  "name": "@zebrash/node",
  "version": "0.1.0",
  "description": "Render ZPL labels to PNG on Node.js. Pure TypeScript port of ingridhq/zebrash.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
