{
  "name": "@zebrash/node",
  "version": "1.0.1",
  "description": "Render ZPL labels to PNG or SVG on Node.js and Bun. Pure TypeScript port of ingridhq/zebrash.",
  "keywords": [
    "barcode",
    "bun",
    "label",
    "label-printer",
    "node",
    "parser",
    "png",
    "renderer",
    "svg",
    "typescript",
    "zebra",
    "zebra-printer",
    "zebrash",
    "zpl",
    "zpl-ii"
  ],
  "homepage": "https://github.com/Fountain-Bio/zebrash-ts#readme",
  "bugs": "https://github.com/Fountain-Bio/zebrash-ts/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fountain-Bio/zebrash-ts.git",
    "directory": "packages/node"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@zebrash/core": "1.0.1",
    "fflate": "^0.8.2"
  },
  "engines": {
    "node": ">=24"
  }
}
