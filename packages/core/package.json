{
  "name": "@zebrash/core",
  "version": "0.1.4",
  "description": "Engine for the @zebrash family — pure-TS ZPL parser + renderer. Internal package; consume @zebrash/node or @zebrash/browser.",
  "homepage": "https://github.com/Fountain-Bio/zebrash-ts#readme",
  "bugs": "https://github.com/Fountain-Bio/zebrash-ts/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fountain-Bio/zebrash-ts.git",
    "directory": "packages/core"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src/assets/fonts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "browser": {
    "./dist/platform.js": "./dist/platform-browser.js",
    "./dist/assets/fonts.js": "./dist/assets/fonts-browser.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser-fonts": {
      "types": "./dist/assets/fonts-browser.d.ts",
      "import": "./dist/assets/fonts-browser.js"
    }
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.100"
  },
  "engines": {
    "node": ">=24"
  }
}
