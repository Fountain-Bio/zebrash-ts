{
  "name": "@zebrash/core",
  "version": "0.1.0",
  "description": "Engine for the @zebrash family — pure-TS ZPL parser + renderer. Internal package; consume @zebrash/node or @zebrash/browser.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src/assets/fonts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {
    "./dist/platform.js": "./dist/platform-browser.js",
    "./dist/assets/fonts.js": "./dist/assets/fonts-browser.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser-fonts": {
      "types": "./dist/assets/fonts-browser.d.ts",
      "import": "./dist/assets/fonts-browser.js"
    }
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.100"
  },
  "engines": {
    "node": ">=20"
  }
}
