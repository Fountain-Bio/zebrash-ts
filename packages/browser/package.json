{
  "name": "@zebrash/browser",
  "version": "0.1.3",
  "description": "Render ZPL labels to PNG in the browser. Pure TypeScript port of ingridhq/zebrash.",
  "homepage": "https://github.com/Fountain-Bio/zebrash-ts#readme",
  "bugs": "https://github.com/Fountain-Bio/zebrash-ts/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fountain-Bio/zebrash-ts.git",
    "directory": "packages/browser"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@zebrash/core": "0.1.3",
    "fflate": "^0.8.2"
  },
  "engines": {
    "node": ">=24"
  }
}
