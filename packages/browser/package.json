{
  "name": "@zebrash/browser",
  "version": "0.1.0",
  "description": "Render ZPL labels to PNG in the browser. Pure TypeScript port of ingridhq/zebrash.",
  "license": "MIT",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@zebrash/core": "workspace:*",
    "fflate": "^0.8.2"
  },
  "engines": {
    "node": ">=24"
  }
}
