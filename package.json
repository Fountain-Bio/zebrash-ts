{
  "name": "zebrash",
  "version": "0.0.0",
  "description": "Pure TypeScript port of ingridhq/zebrash — render ZPL labels as PNG.",
  "license": "MIT",
  "files": [
    "dist",
    "src/assets/fonts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "browser": {
    "./dist/platform.js": "./dist/platform-browser.js",
    "./dist/assets/fonts.js": "./dist/assets/fonts-browser.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run --project node",
    "test:watch": "vitest --project node",
    "test:browser": "bun run build && vitest run --project browser",
    "test:all": "bun run build && vitest run"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/browser": "2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.55"
  },
  "engines": {
    "node": ">=20"
  }
}
